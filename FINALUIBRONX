        for _, obj in ipairs(objects) do
            local cached = Cfg.TransparencyCache[obj]
            local props = Library:GetTransparency(obj)
            if cached and props then
                for _, prop in ipairs(props) do
                    local target = cached[prop]
                    if target ~= nil then
                        if visible then
                            obj[prop] = 1
                            lastTween = Library:Tween(obj, {[prop] = target}, TweenInfo.new(speed or 0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.InOut))
                        else
                            lastTween = Library:Tween(obj, {[prop] = 1}, TweenInfo.new(speed or 0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.InOut))
                        end
                    end
                end
            end
        end

        return lastTween
    end

