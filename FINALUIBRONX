                Cfg.Open = false
            end
        end
    end)

    Items.Alpha.MouseButton1Down:Connect(function() DraggingAlpha = true end)
    Items.RGB.MouseButton1Down:Connect(function() DraggingHue = true end)
    Items.Val.MouseButton1Down:Connect(function() DraggingSat = true end)

    Cfg.Set(Cfg.Color, Cfg.Alpha)
    ConfigFlags[Cfg.Flag] = Cfg.Set
    return setmetatable(Cfg, Library)
end

function Library:Colorpicker(properties)
