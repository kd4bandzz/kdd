task.wait(0.5)
Items.Window.Visible = true

for _, obj in ipairs(Items.Window:GetDescendants()) do
    local props = Library:GetTransparency(obj)
    if props then
        for _, prop in ipairs(props) do
            obj[prop] = 1
        end
    end
end

local windowProps = Library:GetTransparency(Items.Window)
if windowProps then
    for _, prop in ipairs(windowProps) do
        Items.Window[prop] = 1
    end
end

for _, obj in ipairs(Items.Window:GetDescendants()) do
    local props = Library:GetTransparency(obj)
    if props then
        for _, prop in ipairs(props) do
            Library:Fade(obj, prop, true, 0.35)
        end
    end
end

if windowProps then
    for _, prop in ipairs(windowProps) do
        Library:Fade(Items.Window, prop, true, 0.35)
    end
end

IntroGui:Destroy()
